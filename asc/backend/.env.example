# ASC Backend Configuration
# Copy this to .env and fill in your values

# App
APP_NAME=Autonomous Software Company
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/asc
REDIS_URL=redis://localhost:6379/0

# AI / LLM (Qwen via Alibaba Cloud DashScope)
LLM_PROVIDER=qwen
QWEN_API_KEY=your-qwen-api-key-here
QWEN_MODEL=qwen3-72b-instruct
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Memory
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
SECRET_KEY=generate-a-strong-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Alibaba Cloud (for deployment)
ALIBABA_ACCESS_KEY=
ALIBABA_SECRET_KEY=
ALIBABA_REGION=cn-hangzhou